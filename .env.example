# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="StudyTrace"
NEXT_PUBLIC_APP_DESCRIPTION="Academic process proof and appeal evidence chain for international students"
# NEXT_PUBLIC_APP_LOGO="/logo.png"
# NEXT_PUBLIC_APP_FAVICON="/favicon.ico"
# NEXT_PUBLIC_APP_PREVIEW_IMAGE="/preview.png"

# theme / appearance
NEXT_PUBLIC_THEME="default"
NEXT_PUBLIC_APPEARANCE="system"

# i18n
# NEXT_PUBLIC_DEFAULT_LOCALE="en"
# NEXT_PUBLIC_LOCALE_DETECT_ENABLED="false"

# -----------------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------------
DATABASE_PROVIDER="postgresql"
DATABASE_URL=""
DB_SINGLETON_ENABLED="true"
DB_MAX_CONNECTIONS="1"

# -----------------------------------------------------------------------------
# Auth (required)
# -----------------------------------------------------------------------------
# openssl rand -base64 32
AUTH_SECRET=""
# Defaults to NEXT_PUBLIC_APP_URL; set explicitly if auth runs on another origin.
# AUTH_URL=""

# Google auth
GOOGLE_AUTH_ENABLED="false"
GOOGLE_ONE_TAP_ENABLED="false"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub auth
# GITHUB_AUTH_ENABLED="false"
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

# Email verification + password reset (requires Resend)
# EMAIL_VERIFICATION_ENABLED="false"
# RESEND_API_KEY=""
# RESEND_SENDER_EMAIL=""

# -----------------------------------------------------------------------------
# Credits
# -----------------------------------------------------------------------------
# Signup bonus for new users
# INITIAL_CREDITS_ENABLED="true"
# INITIAL_CREDITS_AMOUNT="10"
# INITIAL_CREDITS_VALID_DAYS="30"
# INITIAL_CREDITS_DESCRIPTION="Welcome credits"

# -----------------------------------------------------------------------------
# Payment (enable at least one provider for subscriptions/purchases)
# -----------------------------------------------------------------------------
# Stripe
# STRIPE_ENABLED="false"
# STRIPE_PUBLISHABLE_KEY=""
# STRIPE_SECRET_KEY=""
# STRIPE_SIGNING_SECRET=""

# Creem
# CREEM_ENABLED="false"
# CREEM_ENVIRONMENT="test_mode"
# CREEM_API_KEY=""
# CREEM_SIGNING_SECRET=""
# CREEM_PRODUCT_IDS=""

# PayPal
# PAYPAL_ENABLED="false"
# PAYPAL_ENVIRONMENT="sandbox"
# PAYPAL_CLIENT_ID=""
# PAYPAL_CLIENT_SECRET=""
# PAYPAL_WEBHOOK_ID=""

# -----------------------------------------------------------------------------
# StudyTrace AI analysis
# -----------------------------------------------------------------------------
STUDYTRACE_AI_PROVIDER="evolink"
STUDYTRACE_AI_BASE_URL="https://direct.evolink.ai"
STUDYTRACE_AI_MODEL="MiniMax-M3"
STUDYTRACE_AI_API_KEY=""
STUDYTRACE_ANALYSIS_COST_CREDITS="1"
STUDYTRACE_ANALYSIS_MIN_INTERVAL_MS="5000"
STUDYTRACE_INGEST_COST_CREDITS="1"
STUDYTRACE_INGEST_MIN_INTERVAL_MS="5000"
