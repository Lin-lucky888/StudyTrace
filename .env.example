# app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="StudyTrace"
NEXT_PUBLIC_APP_DESCRIPTION="Academic process proof and appeal evidence chain for international students"

# theme
NEXT_PUBLIC_THEME="default"

# appearance
NEXT_PUBLIC_APPEARANCE="system"

# database
DATABASE_PROVIDER="postgresql"
DATABASE_URL=""
DB_SINGLETON_ENABLED="true"
DB_MAX_CONNECTIONS="1"

# auth secret
# openssl rand -base64 32
AUTH_SECRET=""

# StudyTrace AI analysis
STUDYTRACE_AI_PROVIDER="evolink"
STUDYTRACE_AI_BASE_URL="https://direct.evolink.ai"
STUDYTRACE_AI_MODEL="MiniMax-M3"
STUDYTRACE_AI_API_KEY=""
STUDYTRACE_ANALYSIS_COST_CREDITS="1"
STUDYTRACE_ANALYSIS_MIN_INTERVAL_MS="5000"
